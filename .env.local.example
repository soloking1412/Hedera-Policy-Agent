HEDERA_ACCOUNT_ID=0.0.xxxxx
HEDERA_PRIVATE_KEY=0x...

# Choose one provider:

# Option A: Groq — FREE, no credit card, instant at https://console.groq.com
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# LLM_MODEL=llama-3.3-70b-versatile

# Option B: Google Gemini — FREE at https://aistudio.google.com/apikey
# LLM_PROVIDER=google
# GOOGLE_GENERATIVE_AI_API_KEY=AIza...
# LLM_MODEL=gemini-2.0-flash

# Option C: Anthropic — https://console.anthropic.com (needs sk-ant-... key)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-3-5-haiku-20241022

# Option D: OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# Set by: npm run setup (creates provider accounts on testnet)
PROVIDER_WEATHER_ACCOUNT=
PROVIDER_NEWS_ACCOUNT=
PROVIDER_TRANSLATE_ACCOUNT=
PROVIDER_PREMIUM_ACCOUNT=
